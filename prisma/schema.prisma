generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Minimal User model
// Add your project fields below the required ones
model User {
  id        Int       @id @default(autoincrement())
  firstName String
  lastName  String
  email     String    @unique
  password  String
  // add project-specific fields here:
  // isAuthor  Boolean  @default(false)
  createdAt DateTime  @default(now())
  blogs     Blog[]
  comments  Comment[]
}

model Blog {
  id          Int       @id @default(autoincrement())
  title       String
  text        String
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  comments    Comment[]
  authorId    Int
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  blogId    Int
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
}
